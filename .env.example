# ============================================================
#  在庫管理システム 設定ファイル
#  このファイルを .env にコピーして設定してください
#  setup.bat を実行すると自動生成されます
# ============================================================

# ── セキュリティ ─────────────────────────────────────────────
# 本番環境では必ず変更してください（32文字以上のランダム文字列推奨）
SECRET_KEY=inventory-secret-key-change-this

# ── PostgreSQL接続設定 ───────────────────────────────────────
# 同じPC上のPostgreSQL: localhost
# 別サーバーのPostgreSQL: サーバーのIPアドレス（例: 192.168.1.10）
PG_HOST=localhost
PG_PORT=5432
PG_DBNAME=inventory
PG_USER=inventory_user
PG_PASSWORD=your_password_here

# ── アプリポート設定 ─────────────────────────────────────────
# デフォルト: 5000
# 他のサービスとポートが被る場合は変更してください（例: 8080）
PORT=5000

# ── メール設定（SMTP）────────────────────────────────────────
# 発注メール・期限アラートメールの送信に使用
# 使用しない場合は空欄のままでOK
MAIL_SERVER=
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USE_SSL=False
MAIL_AUTH=True
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=
MAIL_FROM_NAME=在庫管理システム

# ── スケジューラー設定 ───────────────────────────────────────
# 毎日のメール送信時刻（24時間表記）
DAILY_MAIL_HOUR=8
DAILY_MAIL_MINUTE=0
# 月次CSVインポート実行時刻
MONTH_END_IMPORT_HOUR=5
MONTH_END_IMPORT_MINUTE=0

# ── サーバー設定 ─────────────────────────────────────────────
# 1: waitress（本番推奨） / 0: Flask開発サーバー
USE_WAITRESS=1
