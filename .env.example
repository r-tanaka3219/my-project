# 在庫管理システム 設定ファイルサンプル
# このファイルを .env にコピーして各値を設定してください
# または setup.bat を実行すると自動生成されます

SECRET_KEY=your-secret-key-here

PG_HOST=localhost
PG_PORT=5432
PG_DBNAME=inventory
PG_USER=inventory_user
PG_PASSWORD=your-db-password

PORT=5000
USE_WAITRESS=1

MAIL_SERVER=
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USE_SSL=False
MAIL_AUTH=True
MAIL_USERNAME=your-email@example.com
MAIL_PASSWORD=your-email-password
MAIL_FROM=your-email@example.com
MAIL_FROM_NAME=在庫管理システム

DAILY_MAIL_HOUR=8
DAILY_MAIL_MINUTE=0
MONTH_END_IMPORT_HOUR=5
MONTH_END_IMPORT_MINUTE=0

WEATHER_LOCATION=東京
WEATHER_LAT=35.6897
WEATHER_LON=139.6922
# 複数地点の場合（JSON形式）- 例: 主要都市
# WEATHER_LOCATIONS_JSON=[{"name":"札幌","lat":43.0618,"lon":141.3545},{"name":"仙台","lat":38.2688,"lon":140.8721},{"name":"東京","lat":35.6897,"lon":139.6922},{"name":"名古屋","lat":35.1815,"lon":136.9066},{"name":"大阪","lat":34.6937,"lon":135.5023},{"name":"広島","lat":34.3853,"lon":132.4553},{"name":"福岡","lat":33.5902,"lon":130.4017},{"name":"那覇","lat":26.2124,"lon":127.6809}]
# 全都道府県を設定する場合はweather_data画面の「複数地点一括取得」を使用してください
